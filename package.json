{
  "name": "@smartsuite/mcp-server",
  "version": "0.9.8",
  "description": "Local MCP server for governed access to SmartSuite solutions, applications, records, fields, comments, and SmartDocs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "smartsuite-mcp": "./dist/index.js"
  },
  "scripts": {
    "clean": "rimraf dist build mcpb/server",
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=build/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/index.js --smoke",
    "pack:mcpb": "npm run bundle && node scripts/package-mcpb.js && cd mcpb && mcpb pack . smartsuite-mcp-server-$npm_package_version.mcpb",
    "docker:build": "docker build -f docker/Dockerfile -t smartsuite/mcp-server:local ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "smartsuite",
    "ai",
    "model-context-protocol"
  ],
  "license": "MIT"
}
